public/uploads/banners/*
public/uploads/gallery/*

# Keep the upload directories
!public/uploads/certificates/.gitkeep
!public/uploads/banners/.gitkeep
!public/uploads/gallery/.gitkeep

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
